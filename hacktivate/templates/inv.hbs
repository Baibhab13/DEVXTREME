<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farmer Inventory</title>
    <link rel="stylesheet" href="inv.css">
</head>
<body>
    <div class="scroll-container">
        <div class="inventory-text">
            Farmer Inventory
        </div>
        <div class="container">
            <div class="card">
                <img src="images/seeds.jpg" alt="Seeds">
                <h3>Seeds</h3>
                <p>High-quality seeds for various crops. Available in different varieties for optimal growth and yield.</p>
                <p>Added Jan 15, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/tools.jpg" alt="Tools">
                <h3>Tools</h3>
                <p>Essential farming tools for plowing, sowing, and harvesting. Durable and easy to use.</p>
                <p>Added Mar 10, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/ogn.webp" alt="Organic Fertilizer">
                <h3>Organic Fertilizer</h3>
                <p>Natural and eco-friendly fertilizers to boost soil health and crop production.</p>
                <p>Added Apr 18, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/animal.jpg" alt="Animals">
                <h3>Farm Animals</h3>
                <p>Livestock including cows, goats, and chickens. Ideal for dairy, meat, and egg production.</p>
                <p>Added May 22, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/animal fed.jpg" alt="Animal Feed">
                <h3>Animal Feed</h3>
                <p>Nutrient-rich feed for livestock to ensure healthy growth and productivity.</p>
                <p>Added Jun 30, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/irrigation.jpg" alt="Irrigation Systems">
                <h3>Irrigation Systems</h3>
                <p>Efficient water management solutions for consistent and optimal crop irrigation.</p>
                <p>Added Aug 12, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/81JuJE47wWL._AC_SL1500_.jpg" alt="Greenhouse Supplies">
                <h3>Greenhouse Supplies</h3>
                <p>Materials and equipment for greenhouse farming to enhance crop growth and protection.</p>
                <p>Added Sep 08, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
            <div class="card">
                <img src="images/tractor.webp" alt="Tractors">
                <h3>Tractors</h3>
                <p>Modern tractors with advanced features for efficient and productive farming.</p>
                <p>Added Oct 25, 2022</p>
                <button>Make changes</button>
                <a href="#">Learn More</a>
            </div>
        </div>
    </div>
</body>
</html>
